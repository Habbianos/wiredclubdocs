				<path d="M6.66466 2.14923C7.09447 2.05151 7.54149 2 8 2C11.3137 2 14 4.68629 14 8C14 11.3137 11.3137 14 8 14C7.54149 14 7.09447 13.9485 6.66466 13.8508C6.43922 13.7995 6.29802 13.5752 6.34927 13.3498C6.40052 13.1243 6.62482 12.9831 6.85026 13.0344C7.21961 13.1184 7.60434 13.1628 8 13.1628C10.8513 13.1628 13.1628 10.8513 13.1628 8C13.1628 5.14867 10.8513 2.83721 8 2.83721C7.60434 2.83721 7.21961 2.88164 6.85026 2.9656C6.62482 3.01686 6.40052 2.87565 6.34927 2.65022C6.29802 2.42478 6.43922 2.20048 6.66466 2.14923Z" fill="white"/>
