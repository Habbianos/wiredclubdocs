				<path d="M2.9656 6.85026C3.01686 6.62482 2.87565 6.40052 2.65022 6.34927C2.42478 6.29802 2.20048 6.43922 2.14923 6.66466C2.05151 7.09447 2 7.54149 2 8C2 8.45851 2.05151 8.90553 2.14923 9.33535C2.20048 9.56078 2.42478 9.70199 2.65022 9.65075C2.87565 9.59946 3.01686 9.3752 2.9656 9.14977C2.88164 8.78039 2.83721 8.39567 2.83721 8C2.83721 7.60434 2.88164 7.21961 2.9656 6.85026Z" fill="white"/>
				<path d="M3.05041 10.6156C3.24605 10.4924 3.5045 10.5511 3.62769 10.7468C4.04069 11.4027 4.5973 11.9593 5.25322 12.3723C5.44885 12.4955 5.50759 12.754 5.3844 12.9496C5.26122 13.1452 5.00276 13.204 4.80713 13.0808C4.04522 12.601 3.39895 11.9548 2.91922 11.1929C2.79604 10.9972 2.85477 10.7388 3.05041 10.6156Z" fill="white"/>
				<path d="M9.90532 7.40893C10.3416 7.66657 10.3416 8.33343 9.90532 8.59107L7.27079 10.1465C6.84672 10.3969 6.32558 10.071 6.32558 9.55542V6.44455C6.32558 5.92901 6.84672 5.60313 7.27079 5.8535L9.90532 7.40893Z" fill="white"/>
			</svg>

			<input id="pr-rate" type="range" min="0.5" max="2" step="0.1" value="1" aria-label="Velocidade" title="Velocidade" />
			<span id="pr-rate-val">1×</span>
		</label>

		<div class="pr-divider"></div>

		<label class="pr-field" title="Tom">
			<!-- <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
				<path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
