---
// PageReader.astro
// Drop this component anywhere in your Starlight layout (e.g. <slot name="sidebar" /> or above content)
// It reads the main article content using the Web Speech API with live highlight.
---

<div id="page-reader" aria-label="Leitor de página">
	<button id="pr-toggle" aria-label="Não disponível" title="Não disponível" disabled>
		<!-- <svg  xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
			<path d="M8 5v14l11-7z"/>
		</svg> -->
		<svg id="pr-icon-play" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
			<path d="M12.7452 6.41155C14.0183 7.1039 14.0183 8.8961 12.7452 9.58844L5.05796 13.7687C3.8206 14.4416 2.29999 13.5658 2.29999 12.1803V3.81974C2.29999 2.43421 3.8206 1.55841 5.05796 2.23129L12.7452 6.41155Z" fill="white"/>
		</svg>

		<!-- <svg id="pr-icon-pause" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="display:none">
			<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
		</svg> -->
		<svg id="pr-icon-pause" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" style="display:none">
			<path d="M2 4.4C2 3.26863 2 2.70294 2.35147 2.35147C2.70294 2 3.26863 2 4.4 2C5.53137 2 6.09706 2 6.44853 2.35147C6.8 2.70294 6.8 3.26863 6.8 4.4V11.6C6.8 12.7314 6.8 13.297 6.44853 13.6485C6.09706 14 5.53137 14 4.4 14C3.26863 14 2.70294 14 2.35147 13.6485C2 13.297 2 12.7314 2 11.6V4.4Z" fill="white"/>
